{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "engram-api",
      "runtimeExecutable": "py",
      "runtimeArgs": ["-m", "uvicorn", "app.main:app", "--port", "8000"],
      "cwd": "services/api",
      "port": 8000
    },
    {
      "name": "engram-web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "apps/web",
      "port": 3000
    }
  ]
}
